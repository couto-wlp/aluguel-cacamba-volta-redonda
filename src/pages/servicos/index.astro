---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import { SITE_CONFIG } from '../../data/config';

const services = await getCollection('servicos');
services.sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Serviços de Aluguel de Caçamba | Caçambas Volta Redonda" description="Aluguel de caçamba em Volta Redonda e serviços especializados. Eficiência na retirada de materiais mistos e construção. Garanta a sua hoje!">
	<!-- 1. Hero / Introdução (Fundo Escuro: bg-secondary) -->
	<section class="bg-secondary text-white py-24 md:py-32 relative overflow-hidden">
		<div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_20%,rgba(250,204,21,0.1),transparent_50%)]"></div>
		<div class="container mx-auto px-6 md:px-12 relative z-10 text-center">
			<span class="inline-flex items-center gap-1.5 px-5 py-2 rounded-full text-xs font-black bg-[#566270] text-primary mb-6 tracking-wider uppercase">
				Nossas Soluções
			</span>
			<h1 class="text-4xl md:text-6xl font-black text-white mt-2 leading-tight max-w-4xl mx-auto tracking-tighter">
				Serviços Especializados de <span class="text-primary">Coleta de Entulho</span>
			</h1>
		</div>
	</section>

	<!-- 2. Lista de Serviços (Fundo Claro: bg-gray-50) -->
	<section class="py-24 md:py-32 bg-gray-50">
		<div class="container mx-auto px-6 md:px-12">
			<div class="max-w-3xl mx-auto text-center mb-16">
				<span class="text-xs uppercase tracking-widest text-secondary font-bold">Modelos Disponíveis</span>
				<h2 class="text-3xl md:text-4xl font-black text-gray-900 mt-2 tracking-tighter">
					Nossos Modelos de Caçambas
				</h2>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				{services.map(service => (
					<div class={`relative bg-white border border-gray-150 rounded-[32px] p-8 flex flex-col justify-between transition-all duration-300 shadow-sm hover:shadow-2xl cursor-pointer ${service.data.popular ? 'border-primary/60 ring-2 ring-primary/10' : ''}`}>
						<div>
							{service.data.image ? (
								<a href={`/servicos/${service.slug}`} class="block w-full h-64 overflow-hidden mb-6 flex items-center justify-center">
									<Image src={service.data.image} alt={service.data.title} class="w-full h-full object-contain" />
								</a>
							) : (
								<a href={`/servicos/${service.slug}`} class="block w-full h-64 mb-6 flex items-center justify-center text-5xl bg-gray-50 rounded-2xl">
									{service.data.icon}
								</a>
							)}
							
							<h2 class="text-2xl font-black text-gray-900 mb-2 hover:text-secondary transition-colors">
								<a href={`/servicos/${service.slug}`}>{service.data.title}</a>
							</h2>
							
							{service.data.capacity && (
								<span class="text-sm font-bold text-secondary mb-4 block">
									{service.data.capacity}
								</span>
							)}
							
							<p class="text-gray-600 text-sm leading-relaxed mb-6">{service.data.description}</p>
						</div>
						
						<a 
							href={`/servicos/${service.slug}`}
							class="w-full text-center py-4 px-6 rounded-2xl bg-secondary text-white font-extrabold text-base hover:bg-slate-800 transition-colors shadow-md block"
						>
							Mais Informações
						</a>
					</div>
				))}
			</div>


		</div>
	</section>
</Layout>
